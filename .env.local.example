# Modo local del restaurante — PostgreSQL nativo en Windows (sin Docker)
# Copiar a .env.local y/o merge en .env del backend

BENTOO_MODE=local
BIND_HOST=0.0.0.0
PORT=4000
BENTOO_DISCOVERY=true
BENTOO_DISCOVERY_PORT=40200
# BENTOO_DISCOVERY_HOST=192.168.1.10

RESTAURANT_ID=
CLOUD_API_URL=https://bentoo.com.ar
EDGE_SYNC_TOKEN=
EDGE_LOCAL_ID=

DATABASE_URL=postgresql://bentoo:bentoo_local_dev@localhost:5432/bentoo_local
JWT_SECRET=dev-local-change-in-production

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/resto_db?schema=public"

# JWT Configuration
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# MercadoPago Configuration
MERCADOPAGO_ACCESS_TOKEN="your-mercadopago-access-token-here"

# Required: 32 bytes key for AES-256-GCM.
# Format: 64 hex chars OR base64-encoded 32 bytes.
MP_TOKEN_ENCRYPTION_KEY=""

# Recommended base URL used to build back_urls and webhook URL
BASE_URL="http://localhost:3000"

# Optional override for MercadoPago notification webhook
MERCADOPAGO_NOTIFICATION_URL=""

# MercadoPago OAuth ("Conectar cuenta") - flujo recomendado para tenants
# Obtener client_id / client_secret en https://www.mercadopago.com.ar/developers
MERCADOPAGO_OAUTH_CLIENT_ID=""
MERCADOPAGO_OAUTH_CLIENT_SECRET=""
# Debe coincidir EXACTAMENTE con la Redirect URI configurada en la app de MP Developers.
# Apunta al backend, ej: https://api.bentoo.com.ar/api/mercadopago/oauth/callback
MERCADOPAGO_OAUTH_REDIRECT_URI=""
# Secret para firmar el state OAuth (CSRF). Mínimo 16 chars, recomendado 32+.
MERCADOPAGO_OAUTH_STATE_SECRET=""

# Application URLs
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3000"
# In production, set to your domain:
# FRONTEND_URL="https://www.bentoo.com.ar"
# BACKEND_URL="https://www.bentoo.com.ar"

# Server Configuration
PORT=3000
NODE_ENV="development"

# DigitalOcean Spaces (S3-compatible) - Image storage
# Required
S3_ENDPOINT="https://sfo2.digitaloceanspaces.com"
S3_REGION="sfo2"
S3_BUCKET="resto-uploads"
S3_KEY=""
S3_SECRET=""

# Optional
# Public base URL if you serve through CDN/Space public endpoint
# Example: https://resto-uploads.sfo2.digitaloceanspaces.com
# Optional: override Bentoo logo URL in transactional emails (defaults to FRONTEND_URL/apple-touch-icon.svg)
BENTOO_EMAIL_LOGO_URL=""
# Optional: fallback proxy origin for email images if S3 presign fails (production only)
# Do NOT use localhost — Gmail/Outlook cannot load it. Usually leave unset.
# EMAIL_PUBLIC_BASE_URL="https://www.bentoo.com.ar"

# Optional: set object ACL on upload (e.g., public-read) if your Space requires it
S3_ACL=""

# If your provider requires path-style URLs
S3_FORCE_PATH_STYLE=false

# Optional key prefix inside the bucket (e.g. resto/)
S3_KEY_PREFIX=""

# ============================================
# Email Configuration (Resend)
# ============================================
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=""

# From email address for outgoing emails
# Must be verified in Resend dashboard
EMAIL_FROM="pedidos@tu-dominio.com"

# Alertas críticas de plataforma (SUPER_ADMIN) vía WhatsApp — no consume cuota Resend.
# Obtener apikey enviando "I allow callmebot to send me messages" a CallMeBot.
# PLATFORM_ALERT_WHATSAPP_PHONE="+54911..."
# PLATFORM_ALERT_WHATSAPP_API_KEY="..."

# Umbrales anti-abuso de registro (opcional)
# REGISTRATION_ABUSE_MAX_PER_IP_HOUR=8
# REGISTRATION_ABUSE_ALERT_GLOBAL_15MIN=8
# REGISTRATION_ABUSE_BLOCK_GLOBAL_15MIN=15
# REGISTRATION_ABUSE_MAX_PER_IDENTITY_DAY=2
# Rechazar alias con "+" en registro (true/1/yes)
# REGISTRATION_REJECT_PLUS_ALIAS=true
# Cierre de emergencia sin entrar al panel (true/1/yes)
# REGISTRATION_DISABLED=true

# Verificación de email obligatoria para owners (default: activa). false/0/no para desactivar.
# Requiere RESEND_API_KEY y FRONTEND_URL para enviar el link a /admin/verify-email
# OWNER_EMAIL_VERIFICATION_REQUIRED=true

# Redis compartido: cola BullMQ (emails), cache Nest y rate limits distribuidos (Throttler).
# Sin REDIS_URL: emails síncronos, cache/throttle en memoria (solo una instancia).
# REDIS_URL=redis://localhost:6379

# Cuota diaria Gemini por usuario autenticado
# ONBOARDING_AI_MAX_DRAFTS_PER_USER_DAY=10
# ONBOARDING_AI_MAX_MENU_DRAFTS_PER_USER_DAY=10

# Cuota diaria de subidas por usuario autenticado
# UPLOAD_MAX_FILES_PER_USER_DAY=80
# UPLOAD_MAX_MB_PER_USER_DAY=100
# PUBLIC_WRITE_ORDERS_MAX_PER_IP_HOUR=12
# PUBLIC_WRITE_ORDERS_MAX_PER_RESTAURANT_IP_HOUR=8
# PUBLIC_WRITE_RESERVATIONS_MAX_PER_IP_HOUR=8
# PUBLIC_WRITE_RESERVATIONS_MAX_PER_RESTAURANT_IP_HOUR=5
# PUBLIC_WRITE_REVIEWS_MAX_PER_IP_HOUR=6
# PUBLIC_WRITE_LOYALTY_LOOKUP_MAX_PER_IP_HOUR=20

# Límites de emails transaccionales (magic link, reset, verificación)
# AUTH_MAGIC_LINK_MAX_PER_IP_HOUR=8
# AUTH_MAGIC_LINK_MAX_PER_EMAIL_HOUR=4
# AUTH_PASSWORD_RESET_MAX_PER_IP_HOUR=8
# AUTH_PASSWORD_RESET_MAX_PER_EMAIL_HOUR=4
# AUTH_EMAIL_VERIFY_MAX_PER_IP_HOUR=8
# AUTH_EMAIL_VERIFY_MAX_PER_EMAIL_HOUR=4
# AUTH_LOGIN_INTENT_MAX_PER_IP_HOUR=30
# AUTH_LOGIN_INTENT_MAX_PER_EMAIL_HOUR=15
# AUTH_LOGIN_MAX_PER_IP_HOUR=40
# AUTH_ACTIVATION_CODE_MAX_PER_IP_HOUR=20
# AUTH_CUSTOMER_SESSION_MAX_PER_IP_HOUR=10
# AUTH_CUSTOMER_SESSION_MAX_PER_EMAIL_HOUR=5
# PUBLIC_WRITE_DELIVERY_QUOTE_MAX_PER_IP_HOUR=40
# PUBLIC_WRITE_DELIVERY_QUOTE_MAX_PER_RESTAURANT_IP_HOUR=25
# PUBLIC_READ_MAX_PER_IP_HOUR=180
# PUBLIC_READ_MAX_PER_RESTAURANT_IP_HOUR=90
# KITCHEN_SSE_MAX_PER_IP_HOUR=30
# KITCHEN_SSE_MAX_PER_RESTAURANT_IP_HOUR=20
# EDGE_SYNC_MAX_PER_IP_HOUR=240
# EDGE_SYNC_MAX_PER_RESTAURANT_IP_HOUR=180
# PUBLIC_WRITE_COUPON_VALIDATE_MAX_PER_IP_HOUR=30
# PUBLIC_WRITE_COUPON_VALIDATE_MAX_PER_RESTAURANT_IP_HOUR=20
# PUBLIC_WRITE_CUSTOMER_PROFILE_MAX_PER_IP_HOUR=30
# PUBLIC_WRITE_CUSTOMER_PROFILE_MAX_PER_RESTAURANT_IP_HOUR=20
# PUBLIC_TOKEN_LOOKUP_MAX_PER_IP_HOUR=60
# PUBLIC_TOKEN_LOOKUP_MAX_PER_RESTAURANT_IP_HOUR=40

# ============================================
# Gemini Onboarding AI
# ============================================
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional override. Defaults to gemini-2.5-flash-lite.
ONBOARDING_AI_MODEL="gemini-2.5-flash-lite"
# LEADS_AI_MODEL="gemini-2.5-flash-lite"   # diagnóstico y mensajes (default: flash-lite)
# LEADS_DISCOVERY_MODEL="gemini-2.5-flash" # prospección con Google Search (NO usar lite)
# LEADS_AI_MAX_DISCOVERIES_PER_USER_DAY=5

# ============================================
# Web Push (notificaciones del navegador en admin/staff)
# ============================================
# Generar par con: node -e "const w=require('web-push'); const k=w.generateVAPIDKeys(); console.log(k)"
# Public y private deben ir juntas; si cambiás las keys, los usuarios deben re-activar push.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Opcional. Default: mailto:soporte@bentoo.com.ar
VAPID_SUBJECT="mailto:soporte@bentoo.com.ar"

# ============================================
# Edge sync (servidor local híbrido)
# ============================================
# Minutos sin heartbeat/pull/push antes de marcar DISCONNECTED y alertar soporte (default 120).
# EDGE_SYNC_STALE_MINUTES=120

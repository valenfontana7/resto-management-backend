    },
    "features": {
      "enableReservations": true,
      "enableDelivery": true,
      "enableTakeaway": true,
      "enableTableOrdering": true,
      "enableReviews": false,
      "enableLoyalty": false,
      "enableNotifications": true,
      "enableDarkMode": false,
      "enableMultiLanguage": false,
      "defaultLanguage": "es"
    }
  }
}

###

### =====================================================
### GRANULAR UPDATE ENDPOINTS
### =====================================================

### Update Theme Only
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/theme
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "colors": {
    "primary": "#9333EA",
    "secondary": "#6366F1",
    "accent": "#EC4899"
  },
  "typography": {
    "fontFamily": "Roboto",
    "headingFont": "Roboto Slab"
  }
}

###

### Update Layout Only
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/layout
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "maxWidth": "1440px",
  "containerPadding": "2rem",
  "headerHeight": "72px"
}

###

### Update Assets Only
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/assets
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "logo": {
    "url": "https://example.com/logo.png",
    "width": 150,
    "height": 50
  },
  "favicon": "https://example.com/favicon.ico",
  "heroImage": "https://example.com/hero.jpg"
}

###

### Update Navigation Section
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/sections/nav
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variant": "sticky",
  "showLogo": true,
  "showSearch": true,
  "showCart": true,
  "transparent": true,
  "links": [
    { "text": "Inicio", "href": "/" },
    { "text": "Menú", "href": "#menu" },
    { "text": "Nosotros", "href": "#about" },
    { "text": "Contacto", "href": "#contact" }
  ]
}

###

### Update Hero Section
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/sections/hero
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "enabled": true,
  "variant": "video",
  "title": "Sabores que Inspiran",
  "subtitle": "Descubre nuestra cocina de autor",
  "minHeight": "80vh",
  "overlay": true,
  "overlayOpacity": 0.5,
  "alignment": "center",
  "ctaButton": {
    "text": "Reservar Mesa",
    "link": "/reservas",
    "variant": "primary"
  }
}

###

### Update Menu Section
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/sections/menu
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variant": "list",
  "columns": 2,
  "showFilters": true,
  "showSearch": true,
  "showImages": true,
  "imageAspectRatio": "16:9",
  "cardStyle": "flat",
  "stickyCategories": true
}

###

### Update Info Section
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/sections/info
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "enabled": true,
  "showAddress": true,
  "showPhone": true,
  "showEmail": true,
  "showHours": true,
  "showMap": true,
  "variant": "split"
}

###

### Update Footer Section
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/sections/footer
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variant": "columns",
  "showLogo": true,
  "showSocial": true,
  "showNewsletter": true,
  "backgroundColor": "#111827",
  "textColor": "#E5E7EB",
  "columns": [
    {
      "title": "Enlaces",
      "links": [
        { "text": "Inicio", "href": "/" },
        { "text": "Menú", "href": "#menu" }
      ]
    },
    {
      "title": "Legal",
      "links": [
        { "text": "Términos", "href": "/terms" },
        { "text": "Privacidad", "href": "/privacy" }
      ]
    }
  ]
}

###

### Update Cart Section
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/sections/cart
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variant": "modal",
  "position": "center",
  "showThumbnails": true,
  "showQuantityControls": true,
  "checkoutButtonText": "Ir a Pagar"
}

###

### Update Mobile Menu
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/mobile-menu
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "variant": "fullscreen",
  "position": "left",
  "showLogo": true,
  "showSearch": true,
  "animation": "fade",
  "overlay": true
}

###

### Update SEO
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/seo
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Mi Restaurante - La Mejor Comida de la Ciudad",
  "description": "Descubre nuestra selección de platos gourmet. Reserva tu mesa ahora.",
  "keywords": ["restaurante", "comida", "gourmet", "reservas"],
  "twitterHandle": "@mirestaurante",
  "structuredData": {
    "enabled": true,
    "type": "Restaurant"
  }
}

###

### Update Advanced Settings
PATCH {{baseUrl}}/restaurants/{{restaurantId}}/builder/advanced
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customCSS": ".hero-title { text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }",
  "analytics": {
    "googleAnalyticsId": "G-XXXXXXXXXX"
  },
  "integrations": {
    "whatsappNumber": "+54 9 11 1234-5678",
    "whatsappMessage": "Hola! Me gustaría hacer un pedido",
    "instagramHandle": "@mirestaurante"
  },
  "features": {
    "enableReservations": true,
    "enableDelivery": true,
    "enableDarkMode": true
  }
}

###

### =====================================================
### PUBLISH/UNPUBLISH ACTIONS
### =====================================================

### Publish Configuration
POST {{baseUrl}}/restaurants/{{restaurantId}}/builder/publish
Authorization: Bearer {{token}}
Content-Type: application/json

###

### Unpublish Configuration
POST {{baseUrl}}/restaurants/{{restaurantId}}/builder/unpublish
Authorization: Bearer {{token}}
Content-Type: application/json

###

### Reset to Default Configuration
POST {{baseUrl}}/restaurants/{{restaurantId}}/builder/reset
Authorization: Bearer {{token}}
Content-Type: application/json

###

### =====================================================
### MIGRATION FROM BRANDING V2
### =====================================================

### Migrate from Old Branding System
POST {{baseUrl}}/restaurants/{{restaurantId}}/builder/migrate-from-branding
Authorization: Bearer {{token}}
Content-Type: application/json

###

### =====================================================
### PUBLIC ENDPOINTS (NO AUTH REQUIRED)
### =====================================================

### Get Published Config (Public)
GET {{baseUrl}}/public/restaurants/{{restaurantId}}/builder/config
Content-Type: application/json

###

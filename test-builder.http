### Test Builder API Endpoints
### Prerequisites: Replace {{token}} with a valid JWT and {{restaurantId}} with a valid restaurant ID

@baseUrl = http://localhost:4000
@token = YOUR_JWT_TOKEN_HERE
@restaurantId = YOUR_RESTAURANT_ID_HERE

### =====================================================
### BUILDER CONFIGURATION ENDPOINTS
### =====================================================

### Get Builder Config (creates default if not exists)
GET {{baseUrl}}/api/restaurants/{{restaurantId}}/builder/config
Authorization: Bearer {{token}}
Content-Type: application/json

### Response shape:
### {
###   "success": true,
###   "data": {
###     "config": { ... },
###     "restaurant": { ...previewState, "branding": { ...effectivePreviewBranding } },
###     "publishedRestaurant": { ...livePublishedState }
###   }
### }

###

### Get Builder Metadata (version, dates, publish status)
GET {{baseUrl}}/api/restaurants/{{restaurantId}}/builder/metadata
Authorization: Bearer {{token}}
Content-Type: application/json

###

### Partial Update - Theme Colors Only
PATCH {{baseUrl}}/api/restaurants/{{restaurantId}}/builder/config
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "theme": {
    "colors": {
      "primary": "#FF5722",
      "secondary": "#2196F3",
      "accent": "#4CAF50",
      "background": "#FAFAFA",
      "text": "#212121"
    }
  }
}

###

### Partial Update - Multiple Sections
PATCH {{baseUrl}}/api/restaurants/{{restaurantId}}/builder/config
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "theme": {
    "colors": {
      "primary": "#E91E63"
    },
    "typography": {
      "fontFamily": "Poppins",
      "headingFont": "Montserrat"
    }
  },
  "sections": {
    "hero": {
      "enabled": true,
      "variant": "image",
      "title": "Bienvenidos a Nuestro Restaurante",
      "subtitle": "La mejor experiencia gastronómica"
    }
  }
}

###

### Replace Entire Config (PUT)
PUT {{baseUrl}}/api/restaurants/{{restaurantId}}/builder/config
Authorization: Bearer {{token}}
Content-Type: application/json

### Notes:
### - version y lastModified son opcionales; el backend los completa.
### - si querés preview draft, usá data.restaurant y no /restaurants/me.

{
  "theme": {
    "colors": {
      "primary": "#3B82F6",
      "secondary": "#1E40AF",
      "accent": "#F59E0B",
      "background": "#FFFFFF",
      "text": "#1F2937",
      "textMuted": "#6B7280",
      "border": "#E5E7EB",
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "card": "#FFFFFF",
      "cardHover": "#F9FAFB",
      "overlay": "rgba(0, 0, 0, 0.5)"
    },
    "typography": {
      "fontFamily": "Inter",
      "headingFont": "Inter",
      "fontSize": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem",
        "4xl": "2.25rem"
      },
      "fontWeight": {
        "normal": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "lineHeight": {
        "tight": 1.25,
        "normal": 1.5,
        "relaxed": 1.75
      }
    },
    "spacing": {
      "unit": 4,
      "containerPadding": "1rem",
      "sectionGap": "2rem",
      "cardPadding": "1rem"
    },
    "borderRadius": {
      "none": "0",
      "sm": "0.25rem",
      "md": "0.5rem",
      "lg": "1rem",
      "xl": "1.5rem",
      "full": "9999px"
    },
    "shadows": {
      "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
      "md": "0 4px 6px rgba(0, 0, 0, 0.1)",
      "lg": "0 10px 15px rgba(0, 0, 0, 0.1)",
      "xl": "0 20px 25px rgba(0, 0, 0, 0.15)"
    },
    "animations": {
      "duration": {
        "fast": "150ms",
        "normal": "300ms",
        "slow": "500ms"
      },
      "easing": {
        "default": "cubic-bezier(0.4, 0, 0.2, 1)",
        "in": "cubic-bezier(0.4, 0, 1, 1)",
        "out": "cubic-bezier(0, 0, 0.2, 1)",
        "bounce": "cubic-bezier(0.68, -0.55, 0.265, 1.55)"
      }
    }
  },
  "layout": {
    "maxWidth": "1280px",
    "containerPadding": "1rem",
    "headerHeight": "64px",
    "footerHeight": "auto",
    "sidebarWidth": "280px",
    "gridColumns": 12,
    "gridGap": "1rem"
  },
  "assets": {
    "logo": {
      "url": "",
      "width": 120,
      "height": 40
    },
    "favicon": "",
    "heroImage": "",
    "backgroundImage": "",
    "gallery": []
  },
  "sections": {
    "navigation": {
      "variant": "fixed",
      "showLogo": true,
      "showSearch": true,
      "showCart": true,
      "showUserMenu": true,
      "menuPosition": "center",
      "transparent": false,
      "links": []
    },
    "hero": {
      "enabled": true,
      "variant": "image",
      "title": "¡Bienvenidos!",
      "subtitle": "La mejor experiencia gastronómica",
      "backgroundImage": "",
      "backgroundColor": "#1F2937",
      "textColor": "#FFFFFF",
      "minHeight": "70vh",
      "overlay": true,
      "overlayOpacity": 0.4,
      "ctaButton": {
        "text": "Ver Menú",
        "link": "#menu",
        "variant": "primary"
      },
      "secondaryButton": null,
      "alignment": "center",
      "animation": "fade"
    },
    "menu": {
      "variant": "grid",
      "columns": 3,
      "showFilters": true,
      "showSearch": true,
      "showPrices": true,
      "showDescriptions": true,
      "showImages": true,
      "imageAspectRatio": "4:3",
      "cardStyle": "elevated",
      "categoriesPosition": "top",
      "stickyCategories": true
    },
    "info": {
      "enabled": true,
      "showAddress": true,
      "showPhone": true,
      "showEmail": true,
      "showHours": true,
      "showMap": true,
      "showSocial": true,
      "variant": "cards"
    },
    "footer": {
      "variant": "simple",
      "showLogo": true,
      "showSocial": true,
      "showNewsletter": false,
      "showPaymentMethods": true,
      "columns": [],
      "copyrightText": "© 2024 Todos los derechos reservados",

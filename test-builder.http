      "showQuantityControls": true,
      "showSubtotal": true,
      "checkoutButtonText": "Finalizar Pedido"
    }
  },
  "mobileMenu": {
    "variant": "drawer",
    "position": "left",
    "showLogo": true,
    "showSearch": true,
    "showCategories": true,
    "animation": "slide",
    "overlay": true
  },
  "seo": {
    "title": "",
    "description": "",
    "keywords": [],
    "ogImage": "",
    "twitterHandle": "",
    "structuredData": {
      "enabled": true,
      "type": "Restaurant"
    }
  },
  "advanced": {
    "customCSS": "",
    "customJS": "",

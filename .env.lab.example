NODE_ENV=development
BENTOO_RUNTIME_MODE=lab
BENTOO_MODE=cloud
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5442/bentoo_lab
JWT_SECRET=replace-with-a-local-lab-secret-at-least-32-characters
MP_TOKEN_ENCRYPTION_KEY=replace-with-a-local-64-character-hex-key
PORT=4400
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
APP_TIMEZONE=America/Argentina/Buenos_Aires
BENTOO_LAB_ENABLED=true
BENTOO_LAB_INTERNAL_TOKEN=replace-with-a-local-internal-token
BENTOO_LAB_ADMIN_EMAIL=admin@lab.bentoo.invalid
BENTOO_LAB_ADMIN_PASSWORD=replace-with-a-local-lab-password

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  status                RestaurantStatus       @default(ACTIVE)
  name                  String
  type                  String
  cuisineTypes          String[]
  description           String?
  logo                  String?
  coverImage            String?
  email                 String
  phone                 String
  address               String
  city                  String
  country               String
  postalCode            String?
  website               String?
  minOrderAmount        Int                    @default(1000)
  orderLeadTime         Int                    @default(30)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  taxId                 String?
  branding              Json?
  features              Json?
  socialMedia           Json?
  businessRules         Json?
  modulesUpdatedAt      DateTime?
  modulesUpdatedBy      String?
  legalDetails          Json?
  verificationStatus    VerificationStatus     @default(UNVERIFIED)
  onboardingIncomplete  Boolean                @default(true)
  isPublished           Boolean                @default(false)
  isIndexable           Boolean                @default(true)
  // WhatsApp del dueño para alertas críticas (CallMeBot)
  ownerWhatsappPhone    String?
  ownerWhatsappApiKey   String?
  ownerWhatsappEnabled  Boolean                @default(false)
  // Multi-branch support
  parentId              String?
  parent                Restaurant?            @relation("RestaurantBranches", fields: [parentId], references: [id])
  branches              Restaurant[]           @relation("RestaurantBranches")
  adminAuditLogs        AdminAuditLog[]
  hours                 BusinessHour[]
  categories            Category[]
  checkoutSessions      CheckoutSession[]
  deliveryDrivers       DeliveryDriver[]
  deliveryZones         DeliveryZone[]
  dishes                Dish[]
  mercadoPagoCredential MercadoPagoCredential?
  paymentProviders      PaymentProviderCredential[]
  notifications         Notification[]
  orders                Order[]
  reservations          Reservation[]
  roles                 Role[]
  subscription          Subscription?
  tables                Table[]
  tableAreas            TableArea[]
  users                 User[]
  builderConfig         BuilderConfig?
  reviews               Review[]
  deliveryPlatforms     DeliveryPlatform[]
  externalOrders        ExternalOrder[]
  experiments           Experiment[]
  digestPreferences     DigestPreference[]
  customerProfiles      RestaurantCustomerProfile[]
  pushSubscriptions     PushSubscription[]
  memberships           RestaurantMembership[]
  tableSessions         TableSession[]
  cashRegisterSessions  CashRegisterSession[]
  fiscalDocuments       FiscalDocument[]
  terminals             RestaurantTerminal[]
  dailyOperations       DailyOperation[]
  inventoryItems        InventoryItem[]

  @@index([slug])
  @@index([status])
}

model BuilderConfig {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  version      String     @default("1.0.0")
  config       Json
  isPublished  Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([isPublished])
}

model BusinessHour {
  id           String     @id @default(cuid())
  restaurantId String
  dayOfWeek    Int
  isOpen       Boolean    @default(true)
  openTime     String
  closeTime    String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, dayOfWeek])
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  image        String?
  order        Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes       Dish[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model Dish {
  id              String      @id @default(cuid())
  restaurantId    String
  categoryId      String
  name            String
  description     String?
  price           Int
  costPrice       Int?
  salonPrice      Int?
  image           String?
  isAvailable     Boolean     @default(true)
  isAvailableInSalon Boolean  @default(true)
  isFeatured      Boolean     @default(false)
  preparationTime Int?
  calories        Int?
  allergens       String[]    @default([])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  tags            String[]    @default([])
  avgRating       Float       @default(0)
  reviewCount     Int         @default(0)
  category        Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems          OrderItem[]
  tableSessionItems   TableSessionItem[]
  reviews             Review[]
  modifierGroups      ModifierGroup[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([restaurantId, isAvailable])
}

model InventoryItem {
  id             String     @id @default(cuid())
  restaurantId   String
  name           String
  unit           String     @default("unidad")
  currentStock   Float      @default(0)
  minStock       Float      @default(0)
  linkedDishIds  String[]   @default([])
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model ModifierGroup {
  id          String     @id @default(cuid())
  dishId      String
  name        String
  required    Boolean    @default(false)
  minSelect   Int        @default(0)
  maxSelect   Int        @default(1)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  dish        Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  modifiers   Modifier[]

  @@index([dishId])
}

model Modifier {
  id              String              @id @default(cuid())
  groupId         String
  name            String
  priceAdjustment Int                 @default(0)
  isDefault       Boolean             @default(false)
  isAvailable     Boolean             @default(true)
  order           Int                 @default(0)
  group           ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemMods   OrderItemModifier[]

  @@index([groupId])
}

model Order {
  id                  String               @id @default(cuid())
  restaurantId        String
  customerProfileId   String?
  customerName        String
  customerEmail       String?
  customerPhone       String
  type                OrderType
  status              OrderStatus          @default(PENDING)
  paymentMethod       String
  paymentStatus       PaymentStatus        @default(PENDING)
  subtotal            Int
  deliveryFee         Int                  @default(0)
  discount            Int                  @default(0)
  couponId            String?
  couponCode          String?
  tip                 Int                  @default(0)
  total               Int
  deliveryAddress     String?
  deliveryZoneId      String?
  estimatedTime       String?
  tableId             String?
  tableSessionId      String?
  orderSource         OrderSource          @default(ONLINE)
  scheduledFor        DateTime?
  preparedAt          DateTime?
  deliveredAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  notes               String?
  paymentId           String?
  preferenceId        String?
  paymentProvider     String               @default("mercadopago")
  publicTrackingToken String?              @unique
  orderNumber         String
  deliveryNotes       String?
  paidAt              DateTime?
  confirmedAt         DateTime?
  preparingAt         DateTime?
  readyAt             DateTime?
  deliveryOrder       DeliveryOrder?
  deliveryZone        DeliveryZone?        @relation(fields: [deliveryZoneId], references: [id])
  customerProfile     RestaurantCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table               Table?               @relation("TableOrders", fields: [tableId], references: [id])
  tableSession        TableSession?        @relation("SessionComandas", fields: [tableSessionId], references: [id])
  closedSession       TableSession?        @relation("SessionFinalOrder")
  items               OrderItem[]
  statusHistory       OrderStatusHistory[]
  currentTable        Table?               @relation("CurrentTableOrder")
  reviews             Review[]
  externalOrder       ExternalOrder?

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([customerProfileId])
  @@index([restaurantId, status])
  @@index([restaurantId, createdAt])
  @@index([orderNumber])
  @@index([tableSessionId])
}

model CheckoutSession {
  id                  String        @id @default(cuid())
  restaurantId        String
  customerProfileId   String?
  orderNumber         String
  publicTrackingToken String        @unique
  customerName        String
  customerEmail       String?
  customerPhone       String
  type                OrderType
  paymentMethod       String
  paymentStatus       PaymentStatus @default(PENDING)
  paymentId           String?
  preferenceId        String?       @unique
  paymentProvider     String        @default("mercadopago")
  isSandbox           Boolean       @default(false)
  items               Json
  subtotal            Int
  deliveryFee         Int           @default(0)
  discount            Int           @default(0)
  couponId            String?
  couponCode          String?
  tip                 Int           @default(0)
  total               Int
  deliveryAddress     String?
  deliveryZoneId       String?
  deliveryNotes       String?
  tableId             String?
  notes               String?
  paidAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deliveryZone        DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  restaurant          Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customerProfile     RestaurantCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  table               Table?        @relation(fields: [tableId], references: [id])

  @@unique([restaurantId, orderNumber])
  @@index([customerProfileId])
  @@index([restaurantId, createdAt])
}

model OrderItem {
  id                String              @id @default(cuid())
  orderId           String
  dishId            String
  quantity          Int
  unitPrice         Int
  subtotal          Int
  notes             String?
  dish              Dish                @relation(fields: [dishId], references: [id])
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  selectedModifiers OrderItemModifier[]

  @@index([orderId])
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  modifierId  String
  name        String
  priceAdj    Int       @default(0)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier    Modifier  @relation(fields: [modifierId], references: [id])

  @@index([orderItemId])
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  notes      String?
  createdAt  DateTime     @default(now())
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, createdAt])
}

model MercadoPagoCredential {
  restaurantId           String     @id
  accessTokenCiphertext  String
  accessTokenLast4       String?
  refreshTokenCiphertext String?
  refreshTokenLast4      String?
  mpUserId               String?
  scope                  String?
  expiresAt              DateTime?
  livemode               Boolean?
  connectedVia           String     @default("manual") // "manual" | "oauth"
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  isSandbox              Boolean    @default(false)
  publishableKey         String?
  restaurant             Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

// Credenciales genéricas de proveedor de pago (Payway, Stripe, etc.)
model PaymentProviderCredential {
  id             String     @id @default(cuid())
  restaurantId   String
  provider       String     // "payway" | "mercadopago" | etc.
  publicKey      String?
  secretKeyCipher String    // Encriptado AES-256-GCM
  secretKeyLast4 String?
  merchantId     String?    // Payway: site_id / NRO_COMERCIO
  siteId         String?    // Payway: site_transaction_id prefix
  isSandbox      Boolean    @default(false)
  isActive       Boolean    @default(true)
  metadata       Json?      // Campos extra específicos del proveedor
  // Webhook secret por tenant (autogenerado, AES-256-GCM)
  webhookSecretCipher String?
  webhookSecretLast4  String?
  // Resultado del último test de credenciales
  lastTestedAt   DateTime?
  lastTestStatus String?    // "ok" | "failed"
  lastTestError  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, provider])
  @@index([restaurantId])
  @@index([provider])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  provider    String    @default("mercadopago")
  eventKey    String    @unique
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?

  @@index([provider])
  @@index([receivedAt])
}

model Reservation {
  id              String            @id @default(cuid())
  restaurantId    String
  customerProfileId String?
  customerName    String
  customerEmail   String
  customerPhone   String
  date            DateTime
  time            String
  partySize       Int
  status          ReservationStatus @default(PENDING)
  tableId         String?
  specialRequests String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  notes           String?
  customerProfile RestaurantCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  restaurant      Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table           Table?            @relation("TableReservations", fields: [tableId], references: [id])
  currentTable    Table?            @relation("CurrentTableReservation")

  @@index([restaurantId])
  @@index([customerProfileId])
  @@index([restaurantId, date])
  @@index([restaurantId, status])
}

model TableArea {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tables       Table[]
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Table {
  id                   String            @id @default(cuid())
  restaurantId         String
  number               String
  capacity             Int
  status               TableStatus       @default(AVAILABLE)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  areaId               String?
  currentOrderId       String?           @unique
  currentReservationId String?           @unique
  customerName         String?
  occupiedSince        DateTime?
  positionX            Float             @default(0)
  positionY            Float             @default(0)
  shape                TableShape        @default(SQUARE)
  waiter               String?
  checkoutSessions     CheckoutSession[]
  orders               Order[]           @relation("TableOrders")
  reservations         Reservation[]     @relation("TableReservations")
  area                 TableArea?        @relation(fields: [areaId], references: [id])
  currentOrder         Order?            @relation("CurrentTableOrder", fields: [currentOrderId], references: [id])
  currentReservation   Reservation?      @relation("CurrentTableReservation", fields: [currentReservationId], references: [id])
  currentSessionId     String?           @unique
  currentSession       TableSession?     @relation("CurrentTableSession", fields: [currentSessionId], references: [id])
  tableSessions        TableSession[]    @relation("TableSessions")
  restaurant           Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, number])
  @@index([restaurantId, status])
  @@index([areaId])
}

model DeliveryZone {
  id             String          @id @default(cuid())
  restaurantId   String
  name           String
  minOrder       Int
  estimatedTime  String?
  isActive       Boolean         @default(true)
  areas          String[]
  createdAt      DateTime        @default(now())
  deliveryFee    Int
  updatedAt      DateTime        @updatedAt
  deliveryOrders DeliveryOrder[]
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders         Order[]
  checkoutSessions CheckoutSession[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model DeliveryDriver {
  id             String           @id @default(cuid())
  restaurantId   String
  name           String
  phone          String
  email          String?
  vehicle        String?
  licensePlate   String?
  isActive       Boolean          @default(true)
  isAvailable    Boolean          @default(true)
  avatarUrl      String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  deliveryOrders DeliveryOrder[]
  locations      DriverLocation[]

  @@index([restaurantId])
  @@index([restaurantId, isActive, isAvailable])
}

model DeliveryOrder {
  id                    String          @id @default(cuid())
  orderId               String          @unique
  driverId              String?
  zoneId                String?
  deliveryAddress       String
  deliveryLat           Decimal?        @db.Decimal(10, 8)
  deliveryLng           Decimal?        @db.Decimal(11, 8)
  status                DeliveryStatus  @default(READY)
  readyAt               DateTime?
  assignedAt            DateTime?
  pickedUpAt            DateTime?
  deliveredAt           DateTime?
  estimatedDeliveryTime Int?
  distanceKm            Decimal?        @db.Decimal(5, 2)
  deliveryFee           Int
  driverNotes           String?
  customerNotes         String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  driver                DeliveryDriver? @relation(fields: [driverId], references: [id])
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  zone                  DeliveryZone?   @relation(fields: [zoneId], references: [id])

  @@index([orderId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([driverId, status])
}

model DeliveryPlatform {
  id             String           @id @default(cuid())
  restaurantId   String
  platform       PlatformType
  isActive       Boolean          @default(false)
  apiKey         String?
  apiSecret      String?
  storeId        String?
  webhookSecret  String?
  config         Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  externalOrders ExternalOrder[]

  @@unique([restaurantId, platform])
  @@index([restaurantId])
  @@index([platform, isActive])
}

model ExternalOrder {
  id                 String           @id @default(cuid())
  platformId         String
  restaurantId       String
  externalOrderId    String
  externalStatus     String
  internalOrderId    String?          @unique
  customerName       String
  customerPhone      String?
  deliveryAddress    String?
  items              Json
  subtotal           Int
  deliveryFee        Int              @default(0)
  platformFee        Int              @default(0)
  total              Int
  rawPayload         Json?
  syncedAt           DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  platform           DeliveryPlatform @relation(fields: [platformId], references: [id])
  restaurant         Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  internalOrder      Order?           @relation(fields: [internalOrderId], references: [id])

  @@unique([platformId, externalOrderId])
  @@index([restaurantId])
  @@index([externalStatus])
  @@index([createdAt])
}

enum PlatformType {
  PEDIDOS_YA
  RAPPI
  UBER_EATS
  CUSTOM
}

model DriverLocation {
  id        String         @id @default(cuid())
  driverId  String
  lat       Decimal        @db.Decimal(10, 8)
  lng       Decimal        @db.Decimal(11, 8)
  heading   Int?
  speed     Decimal?       @db.Decimal(5, 2)
  timestamp DateTime       @default(now())
  driver    DeliveryDriver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([timestamp(sort: Desc)])
  @@index([driverId, timestamp(sort: Desc)])
}

model Role {
  id           String      @id @default(cuid())
  restaurantId String?
  name         String
  permissions  Json
  color        String      @default("#6366f1")
  isSystemRole Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  users        User[]
  memberships  RestaurantMembership[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model User {
  id                 String              @id @default(cuid())
  restaurantId       String?
  email              String
  password           String
  passwordSetupRequired Boolean          @default(false)
  activationCodeHash String?
  activationCodeExpiresAt DateTime?
  activationCodeAttempts Int             @default(0)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  name               String
  refreshToken       String?
  roleId             String?
  lastLogin          DateTime?
  avatar             String?
  deletedAt          DateTime?
  auditLogsPerformed AdminAuditLog[]
  notifications      Notification[]
  restaurant         Restaurant?         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  role               Role?               @relation(fields: [roleId], references: [id])
  paymentMethods     UserPaymentMethod[]
  loginLinks         AuthLoginLink[]
  passwordResetLinks AuthPasswordResetLink[]
  memberships        RestaurantMembership[]

  @@index([email])
  @@index([restaurantId])
  @@index([restaurantId, roleId])
  @@index([isActive])
}

/// Acceso de un usuario a un restaurante (multi-cuenta por usuario).
/// Permite que una misma identidad opere varios restaurantes y cambie entre ellos.
/// El restaurante "activo" sigue viviendo en User.restaurantId/roleId; esta tabla
/// es la fuente de verdad de a qué restaurantes PUEDE cambiar el usuario.
model RestaurantMembership {
  id           String     @id @default(cuid())
  userId       String
  restaurantId String
  roleId       String?
  isDefault    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  role         Role?      @relation(fields: [roleId], references: [id])

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
}

model AuthLoginLink {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model AuthPasswordResetLink {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

model OnboardingDraft {
  userId    String   @id
  data      Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([updatedAt])
}

model CustomerIdentity {
  id            String                       @id @default(cuid())
  email         String?
  phone         String?
  emailVerified Boolean                      @default(false)
  phoneVerified Boolean                      @default(false)
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  profiles      RestaurantCustomerProfile[]

  @@unique([email])
  @@unique([phone])
  @@index([email])
  @@index([phone])
}

model RestaurantCustomerProfile {
  id             String            @id @default(cuid())
  restaurantId   String
  identityId     String
  displayName    String
  email          String?
  phone          String?
  marketingOptIn Boolean           @default(false)
  defaultAddress Json?
  preferences    Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  identity       CustomerIdentity  @relation(fields: [identityId], references: [id], onDelete: Cascade)
  restaurant     Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders         Order[]
  checkoutSessions CheckoutSession[]
  reservations   Reservation[]
  loyaltyAccounts LoyaltyAccount[]
  loginLinks     CustomerLoginLink[]

  @@unique([restaurantId, identityId])
  @@index([restaurantId])
  @@index([identityId])
  @@index([restaurantId, email])
  @@index([restaurantId, phone])
}

model CustomerLoginLink {
  id                String                    @id @default(cuid())
  customerProfileId String
  tokenHash         String                    @unique
  channel           String                    @default("email")
  expiresAt         DateTime
  usedAt            DateTime?
  createdAt         DateTime                  @default(now())
  customerProfile   RestaurantCustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([customerProfileId])
  @@index([expiresAt])
  @@index([usedAt])
}

model SubscriptionPlan {
  id            String            @id
  displayName   String
  description   String
  price         Int
  interval      String
  trialDays     Int               @default(0)
  color         String
  order         Int               @default(0)
  isActive      Boolean           @default(true)
  isDefault     Boolean           @default(false)
  showOnLanding Boolean           @default(true)
  isPopular     Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  restrictions  PlanRestriction[]
  subscriptions Subscription[]

  @@index([isActive])
  @@index([order])
}

model PlanRestriction {
  id          String           @id @default(cuid())
  planId      String
  key         String
  type        String
  value       String
  displayName String
  description String?
  category    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, key])
  @@index([planId])
  @@index([category])
}

model Subscription {
  id                  String                      @id @default(cuid())
  restaurantId        String                      @unique
  planType            PlanType                    @default(STARTER)
  status              SubscriptionStatus          @default(TRIALING)
  currentPeriodStart  DateTime                    @default(now())
  currentPeriodEnd    DateTime
  trialStart          DateTime?
  trialEnd            DateTime?
  canceledAt          DateTime?
  cancelAtPeriodEnd   Boolean                     @default(false)
  paymentProvider     String                      @default("mercadopago")
  mpSubscriptionId    String?
  mpCustomerId        String?
  mpPayerId           String?
  paymentMethodId     String?
  lastPaymentDate     DateTime?
  lastPaymentAmount   Int?
  nextPaymentDate     DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  userPaymentMethodId String?
  planId              String                      @default("STARTER")
  cancellationReason  String?
  previousPlanType    String?
  isFreeAccount       Boolean                     @default(false)
  discountPercentage  Int?
  discountReason      String?
  discountGrantedBy   String?
  discountGrantedAt   DateTime?
  invoices            Invoice[]
  plan                SubscriptionPlan            @relation(fields: [planId], references: [id])
  restaurant          Restaurant                  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  paymentMethods      SubscriptionPaymentMethod[]

  @@index([restaurantId])
  @@index([status])
  @@index([status, currentPeriodEnd])
}

model UserPaymentMethod {
  id             String   @id @default(cuid())
  userId         String
  mpCustomerId   String?
  mpCardId       String?
  type           String
  brand          String?
  last4          String?
  expiryMonth    Int?
  expiryYear     Int?
  cardholderName String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  issuerId       String?
  issuerName     String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Invoice {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Int
  currency       String       @default("ARS")
  status         String       @default("draft")
  mpPaymentId    String?
  paymentProvider String       @default("mercadopago")
  invoiceUrl     String?
  invoicePdf     String?
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([subscriptionId, createdAt])
}

model SubscriptionPaymentMethod {
  id             String       @id @default(cuid())
  subscriptionId String
  type           String
  brand          String
  last4          String
  expiryMonth    Int
  expiryYear     Int
  isDefault      Boolean      @default(false)
  mpCardId       String?
  createdAt      DateTime     @default(now())
  issuerId       String?
  issuerName     String?
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model AdminAuditLog {
  id                 String      @id @default(cuid())
  adminId            String
  action             String
  details            Json?
  ipAddress          String?
  userAgent          String?
  targetRestaurantId String?
  createdAt          DateTime    @default(now())
  admin              User        @relation(fields: [adminId], references: [id])
  targetRestaurant   Restaurant? @relation(fields: [targetRestaurantId], references: [id])

  @@index([adminId])
  @@index([targetRestaurantId])
}

model Coupon {
  id                   String        @id @default(cuid())
  restaurantId         String
  code                 String
  name                 String
  description          String?
  type                 CouponType
  value                Decimal
  minOrderAmount       Decimal?
  maxDiscountAmount    Decimal?
  usageLimit           Int?
  usageCount           Int           @default(0)
  validFrom            DateTime
  validUntil           DateTime
  isActive             Boolean       @default(true)
  applicableProducts   String[]
  applicableCategories String[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  usages               CouponUsage[]

  @@unique([restaurantId, code])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
  @@index([restaurantId, validUntil])
}

model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String
  orderId        String?
  customerId     String?
  discountAmount Decimal
  usedAt         DateTime @default(now())
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([customerId])
  @@index([usedAt])
}

model Analytics {
  id           String   @id @default(cuid())
  restaurantId String
  date         DateTime @default(now())
  metric       String
  value        Int
  metadata     Json?

  @@index([restaurantId, date])
  @@index([restaurantId, metric])
}

model PushSubscription {
  id           String     @id @default(cuid())
  restaurantId String
  userId       String?
  endpoint     String     @unique
  p256dh       String
  auth         String
  userAgent    String?
  createdAt    DateTime   @default(now())
  lastUsedAt   DateTime?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([userId])
}

model OnboardingEvent {
  id           String   @id @default(cuid())
  sessionId    String
  event        String
  userId       String?
  restaurantId String?
  props        Json?
  createdAt    DateTime @default(now())

  @@index([sessionId])
  @@index([event])
  @@index([createdAt])
  @@index([userId])
  @@index([restaurantId])
}

model Notification {
  id           String                @id @default(cuid())
  userId       String
  restaurantId String?
  type         NotificationType
  title        String
  message      String
  data         Json?
  isRead       Boolean               @default(false)
  priority     NotificationPriority  @default(NORMAL)
  channels     NotificationChannel[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  restaurant   Restaurant?           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([restaurantId])
  @@index([isRead])
  @@index([createdAt])
}

model DemoExample {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  type         String   @default("restaurant")
  cuisine      String[] @default([])
  city         String   @default("")
  neighborhood String   @default("")
  isActive     Boolean  @default(true)
  isFeatured   Boolean  @default(false)
  sortOrder    Int      @default(0)
  payload      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  updatedBy    String?

  @@index([isActive])
  @@index([isFeatured])
  @@index([sortOrder])
  @@index([city])
}

model SystemSettings {
  id                     String   @id @default(cuid())
  platformName           String   @default("Bentoo")
  supportEmail           String   @default("soporte@bentoo.com.ar")
  sessionTimeout         Int      @default(120)
  notifyNewRegistrations Boolean  @default(true)
  notifyPaymentAlerts    Boolean  @default(true)
  notifyDailySummary     Boolean  @default(false)
  adminAlertPreferences  Json?
  webhookEnabled         Boolean  @default(false)
  webhookUrl             String?
  maintenanceEnabled     Boolean  @default(false)
  maintenanceMessage     String?
  updatedAt              DateTime @updatedAt
  updatedBy              String?

  @@map("system_settings")
}


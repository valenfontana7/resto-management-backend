generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Restaurant {
  id                    String                 @id @default(cuid())
  slug                  String                 @unique
  status                RestaurantStatus       @default(ACTIVE)
  name                  String
  type                  String
  cuisineTypes          String[]
  description           String?
  logo                  String?
  coverImage            String?
  email                 String
  phone                 String
  address               String
  city                  String
  country               String
  postalCode            String?
  website               String?
  minOrderAmount        Int                    @default(1000)
  orderLeadTime         Int                    @default(30)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  taxId                 String?
  branding              Json?
  features              Json?
  socialMedia           Json?
  businessRules         Json?
  modulesUpdatedAt      DateTime?
  modulesUpdatedBy      String?
  legalDetails          Json?
  verificationStatus    VerificationStatus     @default(UNVERIFIED)
  onboardingIncomplete  Boolean                @default(true)
  isPublished           Boolean                @default(false)
  isIndexable           Boolean                @default(true)
  // WhatsApp del dueño para alertas críticas (CallMeBot)
  ownerWhatsappPhone    String?
  ownerWhatsappApiKey   String?
  ownerWhatsappEnabled  Boolean                @default(false)
  // Multi-branch support
  parentId              String?
  parent                Restaurant?            @relation("RestaurantBranches", fields: [parentId], references: [id])
  branches              Restaurant[]           @relation("RestaurantBranches")
  adminAuditLogs        AdminAuditLog[]
  hours                 BusinessHour[]
  categories            Category[]
  checkoutSessions      CheckoutSession[]
  deliveryDrivers       DeliveryDriver[]
  deliveryZones         DeliveryZone[]
  dishes                Dish[]
  mercadoPagoCredential MercadoPagoCredential?
  paymentProviders      PaymentProviderCredential[]
  notifications         Notification[]
  orders                Order[]
  reservations          Reservation[]
  roles                 Role[]
  subscription          Subscription?
  tables                Table[]
  tableAreas            TableArea[]
  users                 User[]
  builderConfig         BuilderConfig?
  reviews               Review[]
  deliveryPlatforms     DeliveryPlatform[]
  externalOrders        ExternalOrder[]
  experiments           Experiment[]
  digestPreferences     DigestPreference[]
  customerProfiles      RestaurantCustomerProfile[]
  pushSubscriptions     PushSubscription[]
  memberships           RestaurantMembership[]
  tableSessions         TableSession[]
  cashRegisterSessions  CashRegisterSession[]
  fiscalDocuments       FiscalDocument[]
  terminals             RestaurantTerminal[]
  dailyOperations       DailyOperation[]
  inventoryItems        InventoryItem[]
  businessHealthSnapshots BusinessHealthSnapshot[]
  businessMemories        BusinessMemory[]
  businessEvents          BusinessEvent[]
  winBackEmailLogs        WinBackEmailLog[]
  orderInventoryDeductions OrderInventoryDeduction[]
  edgeLocalServer       EdgeLocalServer?
  engagementDecisions   EngagementDecisionRecord[]
  engagementDeliveries  EngagementDelivery[]
  engagementOutcomes    EngagementOutcome[]
  engagementActiveJourneys EngagementActiveJourney[]
  lifecycleCampaignRuns LifecycleCampaignRun[]
  lifecycleDeliveries     LifecycleDelivery[]
  lifecycleOutcomes       LifecycleOutcome[]
  lifecycleActiveCampaigns LifecycleActiveCampaign[]
  intelligenceSnapshotCache RestaurantIntelligenceSnapshotCache?

  @@index([slug])
  @@index([status])
}

model BuilderConfig {
  id           String     @id @default(cuid())
  restaurantId String     @unique
  version      String     @default("1.0.0")
  config       Json
  isPublished  Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([isPublished])
}

model BusinessHour {
  id           String     @id @default(cuid())
  restaurantId String
  dayOfWeek    Int
  isOpen       Boolean    @default(true)
  openTime     String
  closeTime    String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, dayOfWeek])
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  description  String?
  image        String?
  order        Int        @default(0)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes       Dish[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([restaurantId, isActive])
}

model Dish {
  id              String      @id @default(cuid())
  restaurantId    String
  categoryId      String
  name            String
  description     String?
  price           Int
  costPrice       Int?
  salonPrice      Int?
  image           String?
  isAvailable     Boolean     @default(true)
  autoDisabledByStock Boolean @default(false)
  isAvailableInSalon Boolean  @default(true)
  isFeatured      Boolean     @default(false)
  preparationTime Int?
  calories        Int?
  allergens       String[]    @default([])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  tags            String[]    @default([])
  avgRating       Float       @default(0)
  reviewCount     Int         @default(0)
  category        Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  restaurant      Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems          OrderItem[]
  tableSessionItems   TableSessionItem[]
  reviews             Review[]
  modifierGroups      ModifierGroup[]
  recipeLines         DishRecipeLine[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([restaurantId, isAvailable])
}

model InventoryItem {
  id             String     @id @default(cuid())
  restaurantId   String
  name           String
  unit           String     @default("unidad")
  currentStock   Float      @default(0)
  minStock       Float      @default(0)
  linkedDishIds  String[]   @default([])
  autoDisableDishes Boolean @default(false)
  unitCost       Int?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recipeLines    DishRecipeLine[]

  @@index([restaurantId])
}

model DishRecipeLine {
  id              String        @id @default(cuid())
  dishId          String
  inventoryItemId String
  quantity        Float
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  dish            Dish          @relation(fields: [dishId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([dishId, inventoryItemId])
  @@index([dishId])
  @@index([inventoryItemId])
}

model BusinessHealthSnapshot {
  id           String     @id @default(cuid())
  restaurantId String
  snapshotDate DateTime   @db.Date
  overall      Int
  operational  Int
  commercial   Int
  margin       Int
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, snapshotDate])
  @@index([restaurantId, snapshotDate])
}

model WinBackEmailLog {
  id            String     @id @default(cuid())
  restaurantId  String
  customerKey   String
  customerEmail String
  source        String     @default("manual")
  sentAt        DateTime   @default(now())
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, customerKey, sentAt])
  @@index([restaurantId, sentAt])
}

/// Long-lived semantic memory for continuity (insights shown, recurring issues, recommendations).
/// Distinct from operational tables (orders, inventory rows) — stores *meaning* over time.
model BusinessMemory {
  id              String                 @id @default(cuid())
  restaurantId    String
  /// Stable dedupe key, e.g. `operational:pending-sla` or `inventory:low:mozzarella`
  memoryKey       String
  category        BusinessMemoryCategory
  status          BusinessMemoryStatus   @default(ACTIVE)
  title           String
  summary         String?
  occurrenceCount Int                    @default(1)
  firstSeenAt     DateTime               @default(now())
  lastSeenAt      DateTime               @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
  expiresAt       DateTime?
  sourceProvider  String?
  sourceInsightId String?
  metadata        Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  restaurant      Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, memoryKey])
  @@index([restaurantId, status])
  @@index([restaurantId, category, status])
  @@index([restaurantId, lastSeenAt])
  @@index([expiresAt])
}

/// Append-only log of meaningful business changes — distinct from operational rows.
/// Powers reactive cognitive layers, replay, and future AI agent subscriptions.
model BusinessEvent {
  id            String                    @id @default(cuid())
  restaurantId  String
  /// Canonical type, e.g. OrderCreated, ReservationNoShow
  eventType     String
  /// Module or service that emitted the event
  source        String
  importance    BusinessEventImportance   @default(NORMAL)
  replayPolicy  BusinessEventReplayPolicy @default(FULL)
  payload       Json
  occurredAt    DateTime                  @default(now())
  correlationId String?
  createdAt     DateTime                  @default(now())
  restaurant    Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId, occurredAt])
  @@index([restaurantId, eventType, occurredAt])
  @@index([correlationId])
}

model OrderInventoryDeduction {
  id           String     @id @default(cuid())
  restaurantId String
  orderId      String     @unique
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model ModifierGroup {
  id          String     @id @default(cuid())
  dishId      String
  name        String
  required    Boolean    @default(false)
  minSelect   Int        @default(0)
  maxSelect   Int        @default(1)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  dish        Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  modifiers   Modifier[]

  @@index([dishId])
}

model Modifier {
  id              String              @id @default(cuid())
  groupId         String
  name            String
  priceAdjustment Int                 @default(0)
  isDefault       Boolean             @default(false)
  isAvailable     Boolean             @default(true)
  order           Int                 @default(0)
  group           ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemMods   OrderItemModifier[]

  @@index([groupId])
}

model Order {
  id                  String               @id @default(cuid())
  restaurantId        String
  customerProfileId   String?
  customerName        String
  customerEmail       String?
  customerPhone       String
  type                OrderType
  status              OrderStatus          @default(PENDING)
  paymentMethod       String
  paymentStatus       PaymentStatus        @default(PENDING)
  subtotal            Int
  deliveryFee         Int                  @default(0)
  discount            Int                  @default(0)
  couponId            String?
  couponCode          String?
  tip                 Int                  @default(0)
  total               Int
  deliveryAddress     String?
  deliveryZoneId      String?
  estimatedTime       String?
  tableId             String?
  tableSessionId      String?
  orderSource         OrderSource          @default(ONLINE)
  scheduledFor        DateTime?
  preparedAt          DateTime?
  deliveredAt         DateTime?
  cancelledAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  notes               String?
  paymentId           String?
  preferenceId        String?
  paymentProvider     String               @default("mercadopago")
  publicTrackingToken String?              @unique
  orderNumber         String
  deliveryNotes       String?
  paidAt              DateTime?
  confirmedAt         DateTime?
  preparingAt         DateTime?
  readyAt             DateTime?
  deliveryOrder       DeliveryOrder?
  deliveryZone        DeliveryZone?        @relation(fields: [deliveryZoneId], references: [id])
  customerProfile     RestaurantCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table               Table?               @relation("TableOrders", fields: [tableId], references: [id])
  tableSession        TableSession?        @relation("SessionComandas", fields: [tableSessionId], references: [id])
  closedSession       TableSession?        @relation("SessionFinalOrder")
  items               OrderItem[]
  statusHistory       OrderStatusHistory[]
  currentTable        Table?               @relation("CurrentTableOrder")
  reviews             Review[]
  externalOrder       ExternalOrder?
  inventoryDeduction  OrderInventoryDeduction?

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId])
  @@index([customerProfileId])
  @@index([restaurantId, status])
  @@index([restaurantId, createdAt])
  @@index([orderNumber])
  @@index([tableSessionId])
}

model CheckoutSession {
  id                  String        @id @default(cuid())
  restaurantId        String
  customerProfileId   String?
  orderNumber         String
  publicTrackingToken String        @unique
  customerName        String
  customerEmail       String?
  customerPhone       String
  type                OrderType
  paymentMethod       String
  paymentStatus       PaymentStatus @default(PENDING)
  paymentId           String?
  preferenceId        String?       @unique
  paymentProvider     String        @default("mercadopago")
  isSandbox           Boolean       @default(false)
  items               Json
  subtotal            Int
  deliveryFee         Int           @default(0)
  discount            Int           @default(0)
  couponId            String?
  couponCode          String?
  tip                 Int           @default(0)
  total               Int
  deliveryAddress     String?
  deliveryZoneId       String?
  deliveryNotes       String?
  tableId             String?
  notes               String?
  paidAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deliveryZone        DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  restaurant          Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customerProfile     RestaurantCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  table               Table?        @relation(fields: [tableId], references: [id])

  @@unique([restaurantId, orderNumber])
  @@index([customerProfileId])
  @@index([restaurantId, createdAt])
}

model OrderItem {
  id                String              @id @default(cuid())
  orderId           String
  dishId            String
  quantity          Int
  unitPrice         Int
  subtotal          Int
  notes             String?
  dish              Dish                @relation(fields: [dishId], references: [id])
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  selectedModifiers OrderItemModifier[]

  @@index([orderId])
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  modifierId  String
  name        String
  priceAdj    Int       @default(0)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifier    Modifier  @relation(fields: [modifierId], references: [id])

  @@index([orderItemId])
}

model OrderStatusHistory {
  id         String       @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  changedBy  String?
  notes      String?
  createdAt  DateTime     @default(now())
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, createdAt])
}

model MercadoPagoCredential {
  restaurantId           String     @id
  accessTokenCiphertext  String
  accessTokenLast4       String?
  refreshTokenCiphertext String?
  refreshTokenLast4      String?
  mpUserId               String?
  scope                  String?
  expiresAt              DateTime?
  livemode               Boolean?
  connectedVia           String     @default("manual") // "manual" | "oauth"
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  isSandbox              Boolean    @default(false)
  publishableKey         String?
  restaurant             Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

// Credenciales genéricas de proveedor de pago (Payway, Stripe, etc.)
model PaymentProviderCredential {
  id             String     @id @default(cuid())
  restaurantId   String
  provider       String     // "payway" | "mercadopago" | etc.
  publicKey      String?
  secretKeyCipher String    // Encriptado AES-256-GCM
  secretKeyLast4 String?
  merchantId     String?    // Payway: site_id / NRO_COMERCIO
  siteId         String?    // Payway: site_transaction_id prefix
  isSandbox      Boolean    @default(false)
  isActive       Boolean    @default(true)
  metadata       Json?      // Campos extra específicos del proveedor
  // Webhook secret por tenant (autogenerado, AES-256-GCM)
  webhookSecretCipher String?
  webhookSecretLast4  String?
  // Resultado del último test de credenciales
  lastTestedAt   DateTime?
  lastTestStatus String?    // "ok" | "failed"
  lastTestError  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, provider])
  @@index([restaurantId])
  @@index([provider])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  provider    String    @default("mercadopago")
  eventKey    String    @unique
  payload     Json
  receivedAt  DateTime  @default(now())
  processedAt DateTime?
  error       String?

  @@index([provider])
  @@index([receivedAt])
}

model Reservation {
  id              String            @id @default(cuid())
  restaurantId    String
  customerProfileId String?
  customerName    String
  customerEmail   String
  customerPhone   String
  date            DateTime
  time            String
  partySize       Int
  status          ReservationStatus @default(PENDING)
  tableId         String?
  specialRequests String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  notes           String?
  publicAccessToken String?           @unique
  customerProfile RestaurantCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  restaurant      Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table           Table?            @relation("TableReservations", fields: [tableId], references: [id])
  currentTable    Table?            @relation("CurrentTableReservation")

  @@index([restaurantId])
  @@index([customerProfileId])
  @@index([restaurantId, date])
  @@index([restaurantId, status])
}

model TableArea {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tables       Table[]
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Table {
  id                   String            @id @default(cuid())
  restaurantId         String
  number               String
  capacity             Int
  status               TableStatus       @default(AVAILABLE)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  areaId               String?
  currentOrderId       String?           @unique
  currentReservationId String?           @unique
  customerName         String?
  occupiedSince        DateTime?
  positionX            Float             @default(0)
  positionY            Float             @default(0)
  shape                TableShape        @default(SQUARE)
  waiter               String?
  checkoutSessions     CheckoutSession[]
  orders               Order[]           @relation("TableOrders")
  reservations         Reservation[]     @relation("TableReservations")
  area                 TableArea?        @relation(fields: [areaId], references: [id])
  currentOrder         Order?            @relation("CurrentTableOrder", fields: [currentOrderId], references: [id])
  currentReservation   Reservation?      @relation("CurrentTableReservation", fields: [currentReservationId], references: [id])
  currentSessionId     String?           @unique
  currentSession       TableSession?     @relation("CurrentTableSession", fields: [currentSessionId], references: [id])
  tableSessions        TableSession[]    @relation("TableSessions")
  restaurant           Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, number])
  @@index([restaurantId, status])
  @@index([areaId])
}

model DeliveryZone {
  id             String          @id @default(cuid())
  restaurantId   String
  name           String
  minOrder       Int
  estimatedTime  String?
  isActive       Boolean         @default(true)
  areas          String[]
  createdAt      DateTime        @default(now())
  deliveryFee    Int
  updatedAt      DateTime        @updatedAt
  polygon        Json?
  deliveryOrders DeliveryOrder[]
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orders         Order[]
  checkoutSessions CheckoutSession[]

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model DeliveryDriver {
  id             String           @id @default(cuid())
  restaurantId   String
  userId         String?
  name           String
  phone          String
  email          String?
  vehicle        String?
  licensePlate   String?
  isActive       Boolean          @default(true)
  isAvailable    Boolean          @default(true)
  avatarUrl      String?
  whatsappNotifyEnabled Boolean  @default(false)
  whatsappApiKey        String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  deliveryOrders DeliveryOrder[]
  locations      DriverLocation[]

  @@unique([restaurantId, userId])
  @@index([restaurantId])
  @@index([restaurantId, isActive, isAvailable])
  @@index([userId])
}

model DeliveryOrder {
  id                    String          @id @default(cuid())
  orderId               String          @unique
  driverId              String?
  zoneId                String?
  deliveryAddress       String
  deliveryLat           Decimal?        @db.Decimal(10, 8)
  deliveryLng           Decimal?        @db.Decimal(11, 8)
  status                DeliveryStatus  @default(PENDING)
  readyAt               DateTime?
  assignedAt            DateTime?
  pickedUpAt            DateTime?
  deliveredAt           DateTime?
  estimatedDeliveryTime Int?
  distanceKm            Decimal?        @db.Decimal(5, 2)
  deliveryFee           Int
  driverNotes           String?
  customerNotes         String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  driver                DeliveryDriver? @relation(fields: [driverId], references: [id])
  order                 Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  zone                  DeliveryZone?   @relation(fields: [zoneId], references: [id])

  @@index([orderId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([driverId, status])
}

model DeliveryPlatform {
  id             String           @id @default(cuid())
  restaurantId   String
  platform       PlatformType
  isActive       Boolean          @default(false)
  apiKey         String?
  apiSecret      String?
  storeId        String?
  webhookSecret  String?
  config         Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  restaurant     Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  externalOrders ExternalOrder[]

  @@unique([restaurantId, platform])
  @@index([restaurantId])
  @@index([platform, isActive])
}

model ExternalOrder {
  id                 String           @id @default(cuid())
  platformId         String
  restaurantId       String
  externalOrderId    String
  externalStatus     String
  internalOrderId    String?          @unique
  customerName       String
  customerPhone      String?
  deliveryAddress    String?
  items              Json
  subtotal           Int
  deliveryFee        Int              @default(0)
  platformFee        Int              @default(0)
  total              Int
  rawPayload         Json?
  syncedAt           DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  platform           DeliveryPlatform @relation(fields: [platformId], references: [id])
  restaurant         Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  internalOrder      Order?           @relation(fields: [internalOrderId], references: [id])

  @@unique([platformId, externalOrderId])
  @@index([restaurantId])
  @@index([externalStatus])
  @@index([createdAt])
}

enum PlatformType {
  PEDIDOS_YA
  RAPPI
  UBER_EATS
  CUSTOM
}

model DriverLocation {
  id        String         @id @default(cuid())
  driverId  String
  lat       Decimal        @db.Decimal(10, 8)
  lng       Decimal        @db.Decimal(11, 8)
  heading   Int?
  speed     Decimal?       @db.Decimal(5, 2)
  timestamp DateTime       @default(now())
  driver    DeliveryDriver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId])
  @@index([timestamp(sort: Desc)])
  @@index([driverId, timestamp(sort: Desc)])
}

model Role {
  id           String      @id @default(cuid())
  restaurantId String?
  name         String
  permissions  Json

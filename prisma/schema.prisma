model Subscription {
  id                  String                      @id @default(cuid())
  userId              String?                     @unique
  restaurantId        String                      @unique
  isBillingAnchor     Boolean                     @default(true)
  planType            PlanType                    @default(STARTER)
  status              SubscriptionStatus          @default(TRIALING)
  currentPeriodStart  DateTime                    @default(now())
  currentPeriodEnd    DateTime
  trialStart          DateTime?
  trialEnd            DateTime?
  canceledAt          DateTime?
  cancelAtPeriodEnd   Boolean                     @default(false)
  paymentProvider     String                      @default("mercadopago")
  mpSubscriptionId    String?
  mpCustomerId        String?
  mpPayerId           String?
  paymentMethodId     String?
  lastPaymentDate     DateTime?
  lastPaymentAmount   Int?
  nextPaymentDate     DateTime?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  userPaymentMethodId String?
  planId              String                      @default("STARTER")
  cancellationReason  String?
  previousPlanType    String?
  isFreeAccount       Boolean                     @default(false)
  discountPercentage  Int?

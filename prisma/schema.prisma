model Review {
  id             String     @id @default(cuid())
  restaurantId   String
  orderId        String?
  dishId         String?
  customerName   String
  customerEmail  String?
  rating         Int        // 1-5
  comment        String?
  isApproved     Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  order          Order?     @relation(fields: [orderId], references: [id], onDelete: SetNull)
  dish           Dish?      @relation(fields: [dishId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([restaurantId, isApproved])
  @@index([dishId])
  @@index([orderId])
}

model LoyaltyAccount {
  id             String               @id @default(cuid())
  restaurantId   String
  customerProfileId String?
  customerEmail  String
  customerName   String
  customerPhone  String?
  points         Int                  @default(0)
  totalEarned    Int                  @default(0)
  totalRedeemed  Int                  @default(0)
  tier           LoyaltyTier          @default(BRONZE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  customerProfile RestaurantCustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  transactions   LoyaltyTransaction[]

  @@unique([restaurantId, customerEmail])
  @@index([restaurantId])
  @@index([customerProfileId])
}

model LoyaltyTransaction {
  id          String              @id @default(cuid())
  accountId   String
  type        LoyaltyTxType
  points      Int
  description String?
  orderId     String?
  createdAt   DateTime            @default(now())
  account     LoyaltyAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([accountId, createdAt])
}

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum LoyaltyTxType {
  EARN
  REDEEM
  BONUS
  EXPIRE
}

// A/B Testing
model Experiment {
  id              String            @id @default(cuid())
  restaurantId    String
  name            String
  description     String?
  type            ExperimentType
  targetEntity    String?
  targetEntityId  String?
  isActive        Boolean           @default(false)
  startDate       DateTime?
  endDate         DateTime?
  trafficSplit    Int               @default(50)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  restaurant      Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  variants        ExperimentVariant[]

  @@index([restaurantId])
  @@index([isActive])
}

model ExperimentVariant {
  id             String              @id @default(cuid())
  experimentId   String
  name           String
  isControl      Boolean             @default(false)
  config         Json
  impressions    Int                 @default(0)
  conversions    Int                 @default(0)
  revenue        Int                 @default(0)
  createdAt      DateTime            @default(now())
  experiment     Experiment          @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId])
}

enum ExperimentType {
  PRICE
  MENU_LAYOUT
  DISH_DESCRIPTION
  DISH_IMAGE
}

model DigestPreference {
  id            String          @id @default(cuid())
  restaurantId  String
  email         String
  frequency     DigestFrequency @default(WEEKLY)
  isActive      Boolean         @default(true)
  lastSentAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  restaurant    Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, email])
  @@index([restaurantId])
  @@index([frequency, isActive])
}

enum DigestFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

// ─── Operación de salón (POS / mesas / caja / fiscal) ───────────────────────

enum OrderSource {
  ONLINE
  FLOOR_COMANDA
  FLOOR_FINAL
}

enum TableSessionStatus {
  OPEN
  CLOSING
  CLOSED
  CANCELLED
}

enum ComandaItemStatus {
  PENDING
  SENT
  PREPARING
  READY
  SERVED
  CANCELLED
}

enum CashRegisterSessionStatus {
  OPEN
  CLOSED
}

enum CashRegisterLevel {
  PARTIAL
  MAIN
}

enum CashMovementType {
  SALE
  REFUND
  WITHDRAWAL
  DEPOSIT
  ADJUSTMENT
  OPENING_FLOAT
}

enum FiscalDocumentType {
  INTERNAL_TICKET
  FACTURA_A
  FACTURA_B
  FACTURA_C
  NOTA_CREDITO
}

enum FiscalDocumentStatus {
  DRAFT
  PENDING_AFIP
  AUTHORIZED
  REJECTED
}

model RestaurantTerminal {
  id           String       @id @default(cuid())
  restaurantId String
  name         String
  isActive     Boolean      @default(true)
  lastSeenAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  cashSessions CashRegisterSession[]

  @@unique([restaurantId, name])
}

model TableSession {
  id                    String             @id @default(cuid())
  restaurantId          String
  tableId               String
  sessionNumber         String
  status                TableSessionStatus @default(OPEN)
  waiterId              String?
  waiterName            String?
  guestCount            Int                @default(1)
  customerName          String?
  notes                 String?
  subtotal              Int                @default(0)
  discount              Int                @default(0)
  discountReason        String?
  paymentMethodDiscount Int                @default(0)
  tip                   Int                @default(0)
  total                 Int                @default(0)
  openedAt              DateTime           @default(now())
  closedAt              DateTime?
  orderId               String?            @unique
  cashRegisterSessionId String?
  comandaRound          Int                @default(0)
  restaurant            Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table                 Table              @relation("TableSessions", fields: [tableId], references: [id])
  activeOnTable         Table?             @relation("CurrentTableSession")
  finalOrder            Order?             @relation("SessionFinalOrder", fields: [orderId], references: [id])
  cashRegisterSession   CashRegisterSession? @relation(fields: [cashRegisterSessionId], references: [id])
  items                 TableSessionItem[]
  comandaOrders         Order[]            @relation("SessionComandas")
  fiscalDocuments       FiscalDocument[]
  cashMovements         CashMovement[]

  @@index([restaurantId, status])
  @@index([tableId])
  @@index([restaurantId, openedAt])
}

model TableSessionItem {
  id              String            @id @default(cuid())
  sessionId       String
  dishId          String
  name            String
  quantity        Int
  unitPrice       Int
  subtotal        Int
  notes           String?
  roundNumber     Int               @default(1)
  kitchenStatus   ComandaItemStatus @default(PENDING)
  comandaOrderId  String?
  paidInOrderId   String?
  sentToKitchenAt DateTime?
  createdAt       DateTime          @default(now())
  session         TableSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  dish            Dish              @relation(fields: [dishId], references: [id])
  modifiers       TableSessionItemModifier[]

  @@index([sessionId])
  @@index([sessionId, kitchenStatus])
}

model TableSessionItemModifier {
  id              String           @id @default(cuid())
  sessionItemId   String
  modifierId      String
  name            String
  priceAdjustment Int              @default(0)
  sessionItem     TableSessionItem @relation(fields: [sessionItemId], references: [id], onDelete: Cascade)

  @@index([sessionItemId])
}

model CashRegisterSession {
  id             String                    @id @default(cuid())
  restaurantId   String
  terminalId     String?
  level          CashRegisterLevel         @default(PARTIAL)
  openedByUserId String
  openedByName   String
  openingFloat   Int                       @default(0)
  expectedCash   Int                       @default(0)
  countedCash    Int?
  difference     Int?
  status         CashRegisterSessionStatus @default(OPEN)
  openedAt       DateTime                  @default(now())
  closedAt       DateTime?
  notes          String?
  closeReport    Json?
  restaurant     Restaurant                @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  terminal       RestaurantTerminal?       @relation(fields: [terminalId], references: [id])
  movements      CashMovement[]
  tableSessions  TableSession[]
  sourcedDeposits CashMovement[]           @relation("PartialToMainDeposit")

  @@index([restaurantId, status])
  @@index([restaurantId, status, level])
}

model CashMovement {
  id              String           @id @default(cuid())
  sessionId       String
  tableSessionId  String?
  sourceSessionId String?
  type            CashMovementType
  amount          Int
  paymentMethod   String?
  orderId         String?
  description     String?
  createdByUserId String?
  createdByName   String?
  createdAt       DateTime         @default(now())
  cashSession     CashRegisterSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tableSession    TableSession?    @relation(fields: [tableSessionId], references: [id])
  sourceSession   CashRegisterSession? @relation("PartialToMainDeposit", fields: [sourceSessionId], references: [id])

  @@index([sessionId])
  @@index([tableSessionId])
  @@index([sourceSessionId])
}

model FiscalDocument {
  id                String               @id @default(cuid())
  restaurantId      String
  tableSessionId    String?
  orderId           String?
  type              FiscalDocumentType
  status            FiscalDocumentStatus @default(DRAFT)
  puntoVenta        Int?
  numero            Int?
  cae               String?
  caeExpiresAt      DateTime?
  customerDocType         String?
  customerDocNumber       String?
  customerName            String?
  customerIvaCondition    Int?
  relatedFiscalDocumentId String?
  subtotal                Int
  ivaAmount               Int                  @default(0)
  total                   Int
  payload                 Json?
  pdfUrl                  String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  restaurant              Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tableSession            TableSession?        @relation(fields: [tableSessionId], references: [id])
  relatedFiscalDocument   FiscalDocument?      @relation("FiscalCreditNote", fields: [relatedFiscalDocumentId], references: [id])
  creditNotes             FiscalDocument[]     @relation("FiscalCreditNote")

  @@index([restaurantId])
  @@index([tableSessionId])
  @@index([restaurantId, type, status])
}

model DailyOperation {
  id                 String    @id @default(cuid())
  restaurantId       String
  businessDate       DateTime  @db.Date
  dailyGoal          String?
  openingChecklist   Json?
  openingCompletedAt DateTime?
  openingNotes       String?
  closingChecklist   Json?
  closingCompletedAt DateTime?
  closingNotes       String?
  dailyCloseReport   Json?
  dailyClosedAt      DateTime?
  dailyClosedByName  String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  restaurant         Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, businessDate])
  @@index([restaurantId, businessDate])
}

model FloorClientMutation {
  id               String   @id @default(cuid())
  restaurantId     String
  clientMutationId String
  mutationType     String
  response         Json
  createdAt        DateTime @default(now())

  @@unique([restaurantId, clientMutationId])
  @@index([restaurantId, createdAt])
}
